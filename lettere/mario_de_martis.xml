	<text>
		<body>
			<div type="letter">
				<opener>
					<salute>Caro Zio,</salute>
				</opener>
				<p>
					tra una mezz’ora saremo fucilati tutti e sei. Il mio pensiero corre ora a voi ed alla cara mamma che il destino non ha voluto dovessi riabbracciare.
				</p>
				<p>
					Sarete voi ad avvertirli ed a dire loro che li aspetterò altrove.
				</p>
				<closer>
					<salute>Saluti tanti tanto e baci a tutti dal vostro</salute>
					<signed><persName ref="#Mario_De_Martis">Mario</persName></signed>
				</closer>
			</div>
		</body>
	</text>
