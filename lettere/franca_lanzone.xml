	<text>
		<body>
			<div type="letter">
				<opener>
					<salute>Caro Mario,</salute>
				</opener>
				<p>
					sono le ultime ore della mia <rs type="concept" ref="#vita">vita</rs>, ma con questo vado alla morte senza rancore delle ore vissute.
				</p>
				<p>
					Ricordati i tuoi <rs type="concept" ref="#dovere">doveri</rs> verso di me ti ricorderò sempre
				</p>
				<closer>
					<signed><persName ref="#Franca_Lanzone">Franca</persName></signed>
				</closer>
			</div>
		</body>
